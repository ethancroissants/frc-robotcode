# Cold Fusion Sight per-Pi configuration.
#
# This file lives on the FAT32 boot partition so you can edit it from
# Windows / macOS / Linux *without* booting the Pi — plug the SD card
# into your laptop, edit cfsight.conf, eject, plug into Pi, power on.
#
# If this file is missing or the SSID is blank, the Pi boots into
# AP-mode setup (open network "CFSight-Setup-XXXX"). Connect with
# your phone and follow the captive-portal wizard.
#
# Lines are KEY=VALUE; whitespace and # comments are stripped.

# Your FRC team number (drives hostname `cfsight-NNNN.local`).
TEAM=1279

# Your robot WiFi network. SSID is what shows in WiFi list; PSK is the
# password. Leave PSK= blank for an open network. Country defaults to
# US — change if you're outside the US.
SSID=
PSK=
COUNTRY=US

# Optional: rename the user account on first boot. Default is
# `cfsight` / `cfsight`. CHANGE THE PASSWORD if your Pi is going to be
# accessible from a network you don't trust.
# NEW_USERNAME=
# NEW_PASSWORD=
