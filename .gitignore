# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/

# …but the Manager's electron-builder asset dir is also called `build/`
# by convention (it's the default `nsis.installerSidebar` lookup root),
# and we DO want to commit the installer banners + the custom NSIS
# include. Un-ignore that subtree explicitly. Without this, CI clones
# a tree where `acuity/manager/build/installer-sidebar.bmp` is missing
# and electron-builder fails with "cannot find specified resource".
!acuity/manager/build/
!acuity/manager/build/**

# Virtual environments
.venv/
venv/
env/

# Pytest / mypy / coverage
.pytest_cache/
.mypy_cache/
.coverage

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# RobotPy / Phoenix simulation artifacts
ctre_sim/
logs/
*.hoot
networktables.json
networktables.json.bak
simgui.json
simgui-window.json

# Per-developer push helper. The Python version (push.py) used to
# hardcode a GitHub PAT — that's why this filename was hard-blocklisted.
# The current push.py reads the token from $GH_TOKEN or
# ~/.config/cfsight/gh-token instead, so *push.py is now fine to
# commit*. push.sh is still per-developer though.
push.sh

# Anything that smells like an API token. Belt-and-suspenders so a
# stray credential file can't sneak in even if mis-named.
*.token
*token.txt
**/gh-token
.env
.envrc

# Pi vendoring — laptop-side cached wheels for offline Pi install. Re-fetched
# on every setup_orangepi.py run, so committing them would just churn diffs.
orangepi/vendor/

# Per-laptop Pi target (host/user/cached pi_env) — local config, not source.
.orangepi_cfg

# Pi-image build artifacts (multi-GB images). Don't commit; download
# from GitHub Releases or rebuild via pi-image/build.sh.
pi-image/work/
pi-image/out/
