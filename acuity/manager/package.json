{
  "name": "acuity-manager",
  "version": "0.1.0",
  "description": "Driver-station Manager app for the Acuity vision coprocessor",
  "main": "src/main.js",
  "scripts": {
    "start":        "electron .",
    "dev":          "electron . --enable-logging",
    "build":        "electron-builder",
    "build:mac":    "electron-builder --mac --publish=never",
    "build:win":    "electron-builder --win --publish=never",
    "build:linux":  "electron-builder --linux --publish=never",
    "release:win":  "electron-builder --win --publish=always",
    "release:mac":  "electron-builder --mac --publish=always",
    "release:all":  "electron-builder -mwl --publish=always"
  },
  "license": "MIT",
  "author": "Acuity",
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm":     "^5.5.0",
    "bonjour-service":  "^1.2.1",
    "electron-updater": "^6.3.4",
    "node-pty":         "^1.0.0",
    "ssh2":             "^1.15.0"
  },
  "build": {
    "appId":       "tech.acuity.manager",
    "productName": "Acuity Manager",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/@xterm/**",
      "**/node_modules/ssh2/lib/protocol/crypto/build/**"
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../libraries/templates",
        "to":   "libraries/templates"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner":    "ethancroissants",
        "repo":     "frc-robotcode",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target":   ["dmg", "zip"],
      "identity": null,
      "gatekeeperAssess": false
    },
    "win": {
      "target":     ["nsis", "portable"],
      "icon":       "build/installer-icon.ico",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable":     false
    },
    "portable": {
      "artifactName":  "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick":                false,
      "allowToChangeInstallationDirectory": true,
      "perMachine":              false,
      "createDesktopShortcut":   true,
      "createStartMenuShortcut": true,
      "shortcutName":            "Acuity Manager",
      "menuCategory":            "Acuity",
      "runAfterFinish":          true,
      "deleteAppDataOnUninstall": false,
      "multiLanguageInstaller":  false,
      "installerIcon":           "build/installer-icon.ico",
      "uninstallerIcon":         "build/uninstaller-icon.ico",
      "installerHeaderIcon":     "build/installer-header-icon.ico",
      "installerHeader":         "build/installer-header.bmp",
      "installerSidebar":        "build/installer-sidebar.bmp",
      "uninstallerSidebar":      "build/uninstaller-sidebar.bmp",
      "include":                 "build/installer.nsh",
      "artifactName":            "${productName}-${version}-setup.${ext}"
    },
    "linux": {
      "target":   ["AppImage"],
      "category": "Development"
    }
  }
}
